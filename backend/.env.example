# Backend environment (copy to backend/.env for local dev)
DATABASE_URL=postgresql+psycopg://agora:agora@localhost:5432/agora
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173
FRONTEND_DIST=../frontend/dist

# Fernet key for encrypting clave de elector at rest (REQUIRED — app fails to start without it).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Optional — used by scripts/railway_init.py to seed the first admin.
SEED_ORG_NAME=Atlas Tech
SEED_ORG_SLUG=atlas
SEED_ADMIN_EMAIL=admin@atlas.gov
SEED_ADMIN_PASSWORD=

# Optional — INE México integrations (defaults are sensible; override as needed).
INE_CKAN_BASE_URL=https://datos.gob.mx/api/3/action
INE_CANDIDATURAS_BASE_URL=https://www.apielectoral.mx
INE_SIGE_WMS_URL=
INE_HTTP_TIMEOUT=30
INE_HTTP_RETRIES=3
