# ============================================================================
# Ágora Civic Intelligence — environment template
# ============================================================================

# --- Backend (copy to backend/.env) ----------------------------------------
DATABASE_URL=postgresql+psycopg://agora:agora@localhost:5432/agora
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173
FRONTEND_DIST=../frontend/dist

# Fernet key for encrypting clave de elector at rest (REQUIRED — app fails to start without it).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Seed (scripts/railway_init.py) — set a password to create the first admin.
SEED_ORG_NAME=Atlas Tech
SEED_ORG_SLUG=atlas
SEED_ADMIN_EMAIL=admin@atlas.gov
SEED_ADMIN_PASSWORD=

# INE México integrations (optional overrides).
INE_CKAN_BASE_URL=https://datos.gob.mx/api/3/action
INE_CANDIDATURAS_BASE_URL=https://www.apielectoral.mx
INE_SIGE_WMS_URL=
INE_HTTP_TIMEOUT=30
INE_HTTP_RETRIES=3

# --- Frontend (copy to frontend/.env) --------------------------------------
# In dev the Vite proxy forwards /api → http://localhost:8000.
# In production the backend serves the SPA at the same origin.
VITE_API_URL=/api
